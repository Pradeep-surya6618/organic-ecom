# ─────────────────────────────────────────────────────────────
# BACKEND environment variables
# ─────────────────────────────────────────────────────────────
# Copy this file to "backend/.env.local" and fill in your real values.
# See docs/SETUP_AND_DEPLOYMENT.md for exactly where to get each key.
#
# ⚠️ NEVER commit .env.local — it holds secrets. (It is already gitignored.)
# ⚠️ On Render, set these in the dashboard, NOT in a file.

# ── Server ──
NODE_ENV=development
# PORT: only needed locally. Do NOT set PORT on Render (it provides one automatically).
PORT=5000
# Frontend URL (local: http://localhost:3000 ; production: your Vercel URL)
CLIENT_URL=http://localhost:3000

# ── Database — MongoDB Atlas ──
# https://www.mongodb.com/atlas  (Connect → Drivers → copy string; add DB name at end)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/organic_store

# ── JWT auth secrets ──
# Generate each with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-hex-string
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=replace-with-another-long-random-hex-string
JWT_REFRESH_EXPIRE=7d

# ── Payments — Razorpay ──
# https://dashboard.razorpay.com  (Test Mode → Settings → API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── AI — OpenRouter ──
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
# (optional) preferred model; the app also has its own fallback list
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Email (production) — Brevo HTTPS API ──
# https://www.brevo.com  (verify a sender, then SMTP & API → API Keys)
# Render's free tier blocks SMTP, so production email goes through Brevo.
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (local dev) — Gmail SMTP ──
# App password: https://myaccount.google.com/apppasswords
# Used only when BREVO_API_KEY is not set (i.e. on your PC).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM_NAME=Organic Store
# Must be your VERIFIED Brevo sender in production
SMTP_FROM_EMAIL=you@gmail.com
