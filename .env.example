# ─────────────────────────────────────────────────────────────
# FRONTEND environment variables (Create React App)
# ─────────────────────────────────────────────────────────────
# Copy this file to ".env" (or ".env.local") in the project ROOT and fill in
# your values. CRA only exposes variables prefixed with REACT_APP_, and they are
# read at BUILD/START time — restart `npm start` after changing them.
#
# NOTE: REACT_APP_* values are PUBLIC — they get bundled into the browser JS.
# Never put secrets here (Razorpay secret, JWT secrets, Mongo URI, OpenRouter key
# all belong ONLY in backend/.env.local).

# Base URL of the backend API.
# Local dev:   http://localhost:5000/api/v1
# Production:  https://<your-render-backend>.onrender.com/api/v1
REACT_APP_API_URL=http://localhost:5000/api/v1

# Razorpay PUBLIC key id (the "key id" only — NOT the secret).
# Test:  rzp_test_XXXXXXXXXXXXXX
# Live:  rzp_live_XXXXXXXXXXXXXX
REACT_APP_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
